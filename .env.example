# Copy to .env and fill in. docker-compose reads this file automatically.

# Postgres password used by docker-compose (both the postgres service and the
# app's connection string).
POSTGRES_PASSWORD=waypoint

# --- Server -----------------------------------------------------------------
# Listen address
WAYPOINT_ADDR=:8080
# Postgres connection string (only needed when running the server outside compose)
WAYPOINT_DATABASE_URL=postgres://waypoint:waypoint@localhost:5432/waypoint?sslmode=disable

# --- Auth (M1 — not yet wired up) --------------------------------------------
# Public base URL of this instance, used for OAuth redirect URIs
#WAYPOINT_BASE_URL=https://waypoint.example.com
# Google OAuth client (create at https://console.cloud.google.com/apis/credentials;
# redirect URI: $WAYPOINT_BASE_URL/auth/google/callback)
#WAYPOINT_GOOGLE_CLIENT_ID=
#WAYPOINT_GOOGLE_CLIENT_SECRET=
# Secret for signing session cookies — generate with: openssl rand -hex 32
#WAYPOINT_SESSION_SECRET=
# Allow email/password accounts (intended for dev/testing)
#WAYPOINT_LOCAL_AUTH=false
# Comma-separated list of emails allowed to sign in (empty = first user only)
#WAYPOINT_ALLOWED_EMAILS=

# --- Maps (M3) ----------------------------------------------------------------
# Raster tile URL template; defaults to OpenStreetMap
#WAYPOINT_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
