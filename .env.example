# Copy to .env and fill in. docker-compose reads this file automatically.

# Postgres password used by docker-compose (both the postgres service and the
# app's connection string).
POSTGRES_PASSWORD=waypoint

# --- Server -----------------------------------------------------------------
# Listen address
WAYPOINT_ADDR=:8080
# Postgres connection string (only needed when running the server outside compose)
WAYPOINT_DATABASE_URL=postgres://waypoint:waypoint@localhost:5432/waypoint?sslmode=disable
# Where uploaded files (journal photos) are stored. The docker image uses /data.
#WAYPOINT_DATA_DIR=data

# --- Auth ---------------------------------------------------------------------
# Public base URL of this instance; OAuth redirect URIs derive from it.
# Session cookies are Secure when this is https.
#WAYPOINT_BASE_URL=https://waypoint.example.com
# Google OAuth client (create at https://console.cloud.google.com/apis/credentials;
# redirect URI: $WAYPOINT_BASE_URL/auth/google/callback). Sign in with Google
# is enabled when both are set.
#WAYPOINT_GOOGLE_CLIENT_ID=
#WAYPOINT_GOOGLE_CLIENT_SECRET=
# Generic OIDC provider (Authentik, Keycloak, ...). Issuer is used for
# discovery and must match the provider's discovery document EXACTLY,
# trailing slash included (copy it from the IdP). Redirect URI:
# $WAYPOINT_BASE_URL/auth/oidc/callback. All three must be set together;
# NAME labels the login button (default "SSO").
#WAYPOINT_OIDC_ISSUER_URL=https://auth.example.com/application/o/waypoint/
#WAYPOINT_OIDC_CLIENT_ID=
#WAYPOINT_OIDC_CLIENT_SECRET=
#WAYPOINT_OIDC_NAME=Authentik
# Allow email/password accounts (dev/testing). Create one with `make seed`.
#WAYPOINT_LOCAL_AUTH=false
# Comma-separated emails allowed to sign up after the first user. Empty means
# the instance is closed to new accounts once the first user has signed in.
#WAYPOINT_ALLOWED_EMAILS=

# --- Maps ----------------------------------------------------------------------
# Raster tile URL template; defaults to OpenStreetMap
#WAYPOINT_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
# Optional MapLibre vector style JSON URL (e.g. MapTiler with a key, or a
# self-hosted style). Takes precedence over the raster tiles above, and map
# labels follow WAYPOINT_LANGUAGE. Try https://demotiles.maplibre.org/style.json
#WAYPOINT_MAP_STYLE_URL=
# Geocoding endpoint for place search; defaults to the public OSM instance
#WAYPOINT_NOMINATIM_URL=https://nominatim.openstreetmap.org
# Preferred language for geocoded place names (BCP 47, e.g. en, fr, de).
# Unset keeps native names (東京都 instead of Tokyo). Map tiles are separate — see #66.
#WAYPOINT_LANGUAGE=en
# Serve the MCP endpoint at /mcp so AI assistants can backfill and manage
# trips with a per-user bearer token (created in Settings). Off by default.
#WAYPOINT_MCP=true
