# Git ignore

# Environment and secrets
.env
.env.local
.env.*.local
*.pem
*.key

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependencies
node_modules/
vendor/

# Build outputs
dist/
build/
*.jar
*.war
*.zip
*.tar.gz

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Testing
coverage/
.nyc_output/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
.env

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
/waypoint
/bin/

# Embedded frontend build output
internal/webui/dist/
web/dist/

# Local data (photos, uploads)
/data/

# Misc
*.tmp
*.temp
.cache/

# Stray local builds
/server
