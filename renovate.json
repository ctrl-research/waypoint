{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "America/Toronto",
  "rebaseWhen": "conflicted",
  "commitBodyTable": true,
  "printConfig": true,
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "enabledManagers": [
    "docker-compose",
    "dockerfile",
    "github-actions",
    "gomod",
    "npm"
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "commitMessageTopic": "docker {{depName}}",
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch"
      ],
      "semanticCommitType": "chore",
      "semanticCommitScope": "docker",
      "bumpVersion": "patch",
      "addLabels": [
        "docker"
      ]
    },
    {
      "matchDatasources": [
        "github-actions"
      ],
      "commitMessageTopic": "github action {{depName}}",
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch"
      ],
      "semanticCommitType": "chore",
      "semanticCommitScope": "ci",
      "addLabels": [
        "ci"
      ]
    },
    {
      "matchDatasources": [
        "gomod"
      ],
      "commitMessageTopic": "go module {{depName}}",
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch"
      ],
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps",
      "addLabels": [
        "go"
      ]
    },
    {
      "matchDatasources": [
        "npm"
      ],
      "commitMessageTopic": "npm package {{depName}}",
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch"
      ],
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps",
      "addLabels": [
        "frontend"
      ]
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "addLabels": [
        "major"
      ]
    },
    {
      "matchUpdateTypes": [
        "minor"
      ],
      "addLabels": [
        "minor"
      ]
    },
    {
      "matchUpdateTypes": [
        "patch"
      ],
      "addLabels": [
        "patch"
      ]
    }
  ],
  "labels": [
    "renovate"
  ]
}
